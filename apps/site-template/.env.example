# Which site this deployment renders (sites.slug in the CMS)
SITE_SLUG=
# Read-only content API key for this site (issued when the site is registered)
SITE_API_KEY=
# Base URL of the studio CMS content API (the admin app)
CMS_API_URL=http://127.0.0.1:3000
# Public URL of this site (canonical URLs, sitemap, OG)
SITE_URL=http://localhost:3001
# Secret required by /api/draft to enable preview mode
PREVIEW_SECRET=
# Supabase project URL — only used to allowlist the Storage origin for
# next/image (media itself is served via the content API payload's URLs)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
