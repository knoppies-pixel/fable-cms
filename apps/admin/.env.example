# Local Supabase (values printed by `pnpm supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: form-submission email notifications (Resend). When unset,
# submissions are still persisted and visible in the admin inbox — only the
# notification email is skipped. Per-site recipient lives in
# sites.settings.forms.notifyEmail.
RESEND_API_KEY=
FORMS_FROM_EMAIL=
