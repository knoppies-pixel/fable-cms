{
  "name": "site-fynbos-fern",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/free-port.mjs 3002 && node scripts/build-tokens.mjs",
    "dev": "next dev --port 3002",
    "tokens:build": "node scripts/build-tokens.mjs",
    "prebuild": "node ../../scripts/free-port.mjs 3002 3102 && node scripts/build-tokens.mjs",
    "build": "next build",
    "prestart": "node ../../scripts/free-port.mjs 3002",
    "start": "next start --port 3002",
    "seed": "tsx scripts/seed-content.ts",
    "preview": "pnpm build && pnpm start",
    "lighthouse": "npx --yes lighthouse http://localhost:3002 --chrome-flags=--headless=new --only-categories=performance,accessibility,seo --output=json --output-path=lighthouse.json --quiet",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fable/db": "workspace:*",
    "@fable/sections": "workspace:*",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fable/config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3"
  }
}
